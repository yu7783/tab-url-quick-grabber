{
  "manifest_version": 3,
  "name": "Tab URL Quick Grabber",
  "version": "1.3",
  "description": "ポップアップからサイトを選んでURLを一括コピー",
  "permissions": [
    "tabs",
    "clipboardWrite",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}